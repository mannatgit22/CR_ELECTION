<%@ page language="java" contentType="application/json; charset=UTF-8" pageEncoding="UTF-8"%><%@ page import="java.sql.*"%><%String sic=request.getParameter("sic");String motiv=request.getParameter("motiv");if(sic==null||sic.trim().isEmpty()||motiv==null||motiv.trim().isEmpty()){out.print("{\"success\":false,\"message\":\"SIC and motivation are required\"}");return;}Connection conn=null;PreparedStatement pstmt=null;try{Class.forName("com.mysql.cj.jdbc.Driver");conn=DriverManager.getConnection("jdbc:mysql://localhost:3306/cr_election_db","safe_election","VeryStrongPassword123!");String sql="UPDATE candidates SET motiv = ? WHERE sic = ?";pstmt=conn.prepareStatement(sql);pstmt.setString(1,motiv.trim());pstmt.setString(2,sic.trim());int rowsAffected=pstmt.executeUpdate();if(rowsAffected>0){out.print("{\"success\":true,\"message\":\"Motivation updated successfully\"}");}else{out.print("{\"success\":false,\"message\":\"Candidate not found\"}");}}catch(Exception e){out.print("{\"success\":false,\"message\":\"Error: "+e.getMessage()+"\"}");e.printStackTrace();}finally{if(pstmt!=null)try{pstmt.close();}catch(Exception e){}if(conn!=null)try{conn.close();}catch(Exception e){}}%>
